BasedOnStyle: Google

# Indentation
ColumnLimit: 120
UseTab: Never
IndentWidth: 4
AccessModifierOffset: -4

# Scoping - K&R
BreakBeforeBraces: Attach

# Include grouping and sorting
IncludeBlocks: Regroup
SortIncludes: true
IncludeCategories:
  # 1. Zephyr first
  - Regex: '^<zephyr/.*>'
    Priority: 1
    SortPriority: 0

  # 2. Module headers in angle brackets — any path that ends with .hpp
  - Regex: '^<.*\.hpp>$'
    Priority: 2
    SortPriority: 0

  # 3. C++ standard headers (no slash, no dot) — e.g., <vector>, <string_view>, <cstdio> (c-headers fall here too)
  - Regex: '^<[^/>.]+>$'
    Priority: 3
    SortPriority: 0

  # 4. C system headers with .h (vendor/posix, etc.)
  - Regex: '^<.*\.h>$'
    Priority: 4
    SortPriority: 0

  # 5. Local headers in quotes — treat .hpp
  - Regex: '^".*\.hpp"$'
    Priority: 5
    SortPriority: 0

  # 6. Catch-all (anything else)
  - Regex: '.*'
    Priority: 6
    SortPriority: 0

# Misc - pointer alignment and consecutive assignments
DerivePointerAlignment: false
PointerAlignment: Left
AlignConsecutiveAssignments: AcrossEmptyLinesAndComments

# Comments
ReflowComments: false
AlignTrailingComments: true

